{
  "name": "thehangout",
  "private": true,
  "version": "1.0.0alpha",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "tsx server.ts",
    "refactor:arch:dry-run": "node scripts/migrate-architecture.mjs",
    "refactor:arch:apply": "node scripts/migrate-architecture.mjs --apply",
    "refactor:arch:rewrite": "node scripts/migrate-architecture.mjs --rewrite-only",
    "refactor:arch:rename-symbols:dry-run": "node scripts/rename-architecture-symbols.mjs",
    "refactor:arch:rename-symbols:apply": "node scripts/rename-architecture-symbols.mjs --apply",
    "refactor:entity:safe:dry-run": "node scripts/migrate-architecture.mjs --manifest scripts/entity-safe-rename.manifest.json",
    "refactor:entity:safe:apply": "node scripts/migrate-architecture.mjs --manifest scripts/entity-safe-rename.manifest.json --apply",
    "refactor:entity:safe:rename-symbols:dry-run": "node scripts/rename-architecture-symbols.mjs --manifest scripts/entity-safe-symbol-renames.manifest.json",
    "refactor:entity:safe:rename-symbols:apply": "node scripts/rename-architecture-symbols.mjs --manifest scripts/entity-safe-symbol-renames.manifest.json --apply",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "express": "^5.2.1",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "three": "^0.183.1",
    "ws": "^8.19.0"
  }
}
